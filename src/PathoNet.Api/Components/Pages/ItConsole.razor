@page "/blazor/it"
@page "/blazor/administracja"
@attribute [Authorize(Policy = PathoNetPermissions.OtaView)]
@inject BlazorPortalService PortalService

@if (_loading)
{
    <section class="panel-card">
        <p class="inline-status">Ladowanie administracji...</p>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <section class="panel-card">
        <StatusBadge Tone="critical">Blad</StatusBadge>
        <p>@_error</p>
    </section>
}
else if (_state is not null)
{
    var ota = _state.OtaState;
    var services = _state.ServiceHealth.Services;

    <section class="hero-band">
        <article class="hero-card">
            <p class="eyebrow">Administracja</p>
            <h2>OTA, konfiguracja techniczna i dostep</h2>
            <p class="hero-copy">
                Sekcja administracyjna skupia pakiety OTA, kampanie aktualizacyjne, zdrowie uslug backendowych
                oraz techniczne punkty wejscia API, kontroli dostepu i narzedzia utrzymaniowe.
            </p>
        </article>

        <article class="hero-card accent">
            <p class="eyebrow">Szybkie przejscia</p>
            <div class="route-grid">
                <article class="route-card">
                    <span class="chip info">ota</span>
                    <h3>Edytor OTA</h3>
                    <p>Zarzadzaj pakietami, kampaniami i harmonogramem wdrozen.</p>
                    <a class="route-link" href="/blazor/ota">Otworz OTA</a>
                </article>
                <article class="route-card">
                    <span class="chip info">api</span>
                    <h3>API info</h3>
                    <p>Podglad technicznych endpointow i diagnostyki backendu.</p>
                    <a class="route-link" href="/api/info" target="_blank" rel="noreferrer">Otworz API</a>
                </article>
                <article class="route-card">
                    <span class="chip info">dostep</span>
                    <h3>Panel uprawnien</h3>
                    <p>Uzytkownicy, role i dostep administracyjny do systemu.</p>
                    <a class="route-link" href="/blazor/access">Otworz panel</a>
                </article>
                <article class="route-card">
                    <span class="chip info">reguly</span>
                    <h3>Edytor regul</h3>
                    <p>Pelny edytor mapowan, odbiorcow i progow eskalacji.</p>
                    <a class="route-link" href="/blazor/rules">Otworz reguly</a>
                </article>
                <article class="route-card">
                    <span class="chip info">zdrowie</span>
                    <h3>Zdrowie uslug</h3>
                    <p>Monitor procesow, restartow i watchdogow wspierajacych backend.</p>
                    <a class="route-link" href="/blazor/health">Otworz zdrowie</a>
                </article>
                <article class="route-card">
                    <span class="chip info">lokalnie</span>
                    <h3>Lokalny PNC</h3>
                    <p>Awaryjne wejscie lokalne na urzadzenie przy pracy onsite i bez hosta.</p>
                    <a class="route-link" href="/local">Otworz lokalny PNC</a>
                </article>
                <article class="route-card">
                    <span class="chip info">sygnaly</span>
                    <h3>Diagnostyka sygnalow</h3>
                    <p>Surowe notify, heartbeaty, telemetryka LTE i warstwa symulacji przejsciowej.</p>
                    <a class="route-link" href="/blazor/diagnostyka">Otworz diagnostyke</a>
                </article>
            </div>
        </article>
    </section>

    <MetricGrid>
        <MetricTile Label="Pakiety OTA" Value="@ota.Summary.PackageCount.ToString()" Caption="Repo aktualizacji" />
        <MetricTile Label="Kampanie" Value="@ota.Summary.CampaignCount.ToString()" Caption="Wszystkie rollouty" />
        <MetricTile Label="Zaplanowane" Value="@ota.Summary.ScheduledCount.ToString()" Caption="Oczekujace wdrozenia" />
        <MetricTile Label="Logi OTA" Value="@ota.Summary.LogCount.ToString()" Caption="Wyniki egzekucji kampanii" />
        <MetricTile Label="Uslugi online" Value="@_state.ServiceHealth.Summary.OnlineCount.ToString()" Caption="Procesy techniczne gotowe do pracy" />
        <MetricTile Label="Restarty" Value="@_state.ServiceHealth.Summary.RecentRestartCount.ToString()" Caption="Ostatnie akcje operacyjne" />
    </MetricGrid>

    <section class="content-grid two-up">
        <article class="panel-card">
            <SectionHeader Eyebrow="Kampanie OTA" Title="Najblizsze wdrozenia" />
            <div class="stack-list">
                @foreach (var campaign in ota.Campaigns.Take(6))
                {
                    <article class="stack-item">
                        <div class="pill-row">
                            <StatusBadge Tone="@MapStatusTone(campaign.Status)">@campaign.Status</StatusBadge>
                            <StatusBadge Kind="chip" Tone="info">@campaign.PackageName @campaign.PackageVersion</StatusBadge>
                        </div>
                        <strong>@campaign.Title</strong>
                        <p>@campaign.Summary</p>
                        <p class="detail-copy">celow @campaign.TargetCount / termin @campaign.ScheduledForUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                    </article>
                }
            </div>
        </article>

        <article class="panel-card">
            <SectionHeader Eyebrow="Zdrowie backendu" Title="Procesy i uslugi" />
            <div class="stack-list">
                @foreach (var service in services)
                {
                    <article class="stack-item">
                        <div class="pill-row">
                            <StatusBadge Tone="@MapStatusTone(service.Status)">@service.Status</StatusBadge>
                            <StatusBadge Kind="chip" Tone="info">@service.RuntimeMode</StatusBadge>
                        </div>
                        <strong>@service.DisplayName</strong>
                        <p>@service.Summary</p>
                        <p class="detail-copy">PID @(service.ProcessId?.ToString() ?? "-") / restarty @service.RestartCount / watchdog @(service.WatchdogActive ? "aktywny" : "wylaczony")</p>
                    </article>
                }
            </div>
        </article>
    </section>

    <section class="content-grid two-up">
        <article class="panel-card">
            <SectionHeader Eyebrow="Pakiety" Title="Repo software" />
            <div class="stack-list">
                @foreach (var packageItem in ota.Packages.Take(6))
                {
                    <article class="stack-item">
                        <div class="pill-row">
                            <StatusBadge Kind="chip" Tone="info">@packageItem.Target</StatusBadge>
                            <StatusBadge Tone="@(packageItem.Mandatory ? "critical" : "info")">@(packageItem.Mandatory ? "mandatory" : "opcjonalna")</StatusBadge>
                        </div>
                        <strong>@packageItem.Name @packageItem.Version</strong>
                        <p>@packageItem.Description</p>
                        <p class="detail-copy">@packageItem.FileName / @packageItem.SizeMb.ToString("0.0") MB</p>
                    </article>
                }
            </div>
        </article>

        <article class="panel-card">
            <SectionHeader Eyebrow="API i logi" Title="Techniczne wejscia" />
            <div class="stack-list">
                <article class="stack-item">
                    <strong>API info</strong>
                    <p>Podstawowy katalog endpointow diagnostycznych i portalowych.</p>
                    <p class="detail-copy">/api/info, /api/portal/state, /api/portal/service-health, /api/portal/ota</p>
                </article>
                @foreach (var log in ota.Logs.Take(5))
                {
                    <article class="stack-item">
                        <div class="pill-row">
                            <StatusBadge Tone="@MapStatusTone(log.Level)">@log.Level</StatusBadge>
                            <StatusBadge Kind="chip" Tone="info">@log.DeviceCode</StatusBadge>
                        </div>
                        <strong>@log.CampaignId</strong>
                        <p>@log.Message</p>
                        <p class="detail-copy">@log.OccurredAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                    </article>
                }
            </div>
        </article>
    </section>
}

@code {
    private BlazorServiceDashboardState? _state;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync() =>
        await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _state = await PortalService.GetServiceDashboardAsync(CancellationToken.None);
        }
        catch (Exception ex)
        {
            _error = $"Nie udalo sie zaladowac sekcji administracyjnej: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private static string MapStatusTone(string value) =>
        value.ToLowerInvariant() switch
        {
            "completed" => "online",
            "online" => "online",
            "scheduled" => "info",
            "partial" => "attention",
            "attention" => "attention",
            "warn" => "attention",
            "failed" => "critical",
            "critical" => "critical",
            "alarm" => "critical",
            "error" => "critical",
            _ => "info"
        };
}

@page "/blazor/access"
@attribute [Authorize(Policy = PathoNetPermissions.UsersView)]
@inject IdentityAccessService AccessService

@if (_loading)
{
    <section class="panel-card">
        <p class="inline-status">Ladowanie bazy uzytkownikow...</p>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <section class="panel-card">
        <StatusBadge Tone="critical">Blad</StatusBadge>
        <p>@_error</p>
    </section>
}
else if (_state is not null)
{
    var summary = _state.Summary;
    var users = _state.Users;
    var roles = _state.Roles;
    var permissions = _state.Permissions;
    var auditLog = _state.AuditLog.Take(12).ToArray();

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <section class="panel-card">
            <div class="pill-row">
                <StatusBadge Tone="@_statusTone">IAM</StatusBadge>
                <StatusBadge Kind="chip" Tone="info">SQLite</StatusBadge>
                <StatusBadge Kind="chip" Tone="info">style Django auth</StatusBadge>
            </div>
            <p>@_statusMessage</p>
        </section>
    }

    <section class="hero-band">
        <article class="hero-card">
            <p class="eyebrow">Panel uprawnien i dostepu</p>
            <h2>Baza uzytkownikow, rol i uprawnien</h2>
            <p class="hero-copy">
                Ten modul trzyma lokalna baze dostepu dla PathoNet: konta, role, katalog uprawnien,
                przypisania bezposrednie i audyt zmian administracyjnych. To jest fundament pod dalsze
                podpiecie logowania i realnego egzekwowania dostepu do ekranow oraz akcji serwisowych.
            </p>
            <div class="hero-inline">
                <StatusBadge Tone="online">seed aktywny</StatusBadge>
                <StatusBadge Kind="chip" Tone="info">admin / 123</StatusBadge>
                <StatusBadge Kind="chip" Tone="info">serwis / 123</StatusBadge>
                <StatusBadge Kind="chip" Tone="info">szpital / 123</StatusBadge>
                <StatusBadge Kind="chip" Tone="info">operator / 123</StatusBadge>
            </div>
        </article>

        <article class="hero-card accent">
            <p class="eyebrow">Zakres</p>
            <div class="stack-list">
                <article class="stack-item">
                    <strong>Uzytkownicy</strong>
                    <p>Login, haslo, aktywnosc, konto techniczne i przypisane role.</p>
                </article>
                <article class="stack-item">
                    <strong>Role i uprawnienia</strong>
                    <p>Katalog dostepu do dashboardu, zdrowia uslug, regul, OTA, PNC i panelu IAM.</p>
                </article>
                <article class="stack-item">
                    <strong>Audyt</strong>
                    <p>Historia zmian administracyjnych, gotowa pod dalsze logowanie bezpieczenstwa.</p>
                </article>
            </div>
        </article>
    </section>

    <div class="form-actions">
        <button class="action-button secondary" type="button" @onclick="RefreshAsync">Odswiez</button>
        <a class="action-button secondary" href="/api/identity/state" target="_blank" rel="noreferrer">API IAM</a>
        <a class="action-button secondary" href="/blazor">Powrot do przegladu</a>
    </div>

    <MetricGrid>
        <MetricTile Label="Uzytkownicy" Value="@summary.UserCount.ToString()" Caption="@($"aktywne {summary.ActiveUserCount}")" />
        <MetricTile Label="Role" Value="@summary.RoleCount.ToString()" Caption="Warstwy dostepu biznesowego" />
        <MetricTile Label="Uprawnienia" Value="@summary.PermissionCount.ToString()" Caption="Katalog akcji i widokow" />
        <MetricTile Label="Przypisania rol" Value="@summary.RoleAssignmentCount.ToString()" Caption="Powiazania user -> role" />
        <MetricTile Label="Role -> uprawnienia" Value="@summary.RolePermissionAssignmentCount.ToString()" Caption="Mapowanie systemowe i custom" />
        <MetricTile Label="Nadpisania bezposrednie" Value="@summary.DirectPermissionAssignmentCount.ToString()" Caption="Dodatkowe dostepy userow" />
    </MetricGrid>

    <section class="content-grid two-up">
        <article class="panel-card">
            <SectionHeader Eyebrow="Uzytkownicy" Title="Aktualna baza dostepu" />
            <div class="stack-list">
                @foreach (var user in users)
                {
                    var userRoleNames = roles
                        .Where(role => user.RoleIds.Contains(role.Id, StringComparer.OrdinalIgnoreCase))
                        .Select(role => role.Name)
                        .ToArray();

                    <article class="stack-item">
                        <div class="pill-row">
                            <StatusBadge Tone="@(user.IsActive ? "online" : "critical")">@(user.IsActive ? "aktywny" : "wylaczony")</StatusBadge>
                            @if (user.IsServiceAccount)
                            {
                                <StatusBadge Kind="chip" Tone="attention">konto techniczne</StatusBadge>
                            }
                            <StatusBadge Kind="chip" Tone="info">role @user.RoleIds.Length</StatusBadge>
                            <StatusBadge Kind="chip" Tone="info">efektywne @user.EffectivePermissionCodes.Length</StatusBadge>
                        </div>
                        <strong>@user.FullName</strong>
                        <p class="mono">@user.UserName</p>
                        <p>@(string.Join(", ", userRoleNames.DefaultIfEmpty("brak roli")))</p>
                        <p class="detail-copy">
                            @user.Email / @user.Phone /
                            haslo @(user.LastPasswordChangedAtUtc.HasValue ? user.LastPasswordChangedAtUtc.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "brak")
                        </p>
                        <div class="chip-row">
                            @foreach (var permissionCode in user.EffectivePermissionCodes.Take(6))
                            {
                                <StatusBadge Kind="chip" Tone="info">@permissionCode</StatusBadge>
                            }
                            @if (user.EffectivePermissionCodes.Length > 6)
                            {
                                <StatusBadge Kind="chip" Tone="info">+@(user.EffectivePermissionCodes.Length - 6)</StatusBadge>
                            }
                        </div>
                        @if (_canManage)
                        {
                            <div class="form-actions">
                                <button class="action-button secondary" type="button" @onclick="() => EditUser(user)">Edytuj</button>
                                <button class="action-button danger" type="button" @onclick="() => DeleteUserAsync(user.Id)">Usun</button>
                            </div>
                        }
                    </article>
                }
            </div>
        </article>

        <article class="panel-card">
            <SectionHeader Eyebrow="Edytor uzytkownika" Title="@(_userForm.UserId is null ? "Nowe konto systemowe" : $"Edycja: {_userForm.UserName}")" />
            @if (_canManage)
            {
                <AccessUserForm Model="_userForm" Roles="roles" Permissions="permissions" OnSave="SaveUserAsync" OnReset="ResetUserForm" />
            }
            else
            {
                <p class="empty-state">Masz tylko podglad. Zarzadzanie uzytkownikami wymaga uprawnienia <span class="mono">@PathoNetPermissions.UsersManage</span>.</p>
            }
        </article>
    </section>

    <section class="content-grid two-up">
        <article class="panel-card">
            <SectionHeader Eyebrow="Role" Title="Warstwy dostepu i uprawnien" />
            <div class="stack-list">
                @foreach (var role in roles)
                {
                    <article class="stack-item">
                        <div class="pill-row">
                            <StatusBadge Tone="@(role.IsSystemRole ? "attention" : "info")">@(role.IsSystemRole ? "systemowa" : "custom")</StatusBadge>
                            <StatusBadge Kind="chip" Tone="info">uzytkownicy @role.UserCount</StatusBadge>
                            <StatusBadge Kind="chip" Tone="info">uprawnienia @role.PermissionCodes.Length</StatusBadge>
                        </div>
                        <strong>@role.Name</strong>
                        <p>@role.Description</p>
                        <div class="chip-row">
                            @foreach (var permissionCode in role.PermissionCodes.Take(6))
                            {
                                <StatusBadge Kind="chip" Tone="info">@permissionCode</StatusBadge>
                            }
                            @if (role.PermissionCodes.Length > 6)
                            {
                                <StatusBadge Kind="chip" Tone="info">+@(role.PermissionCodes.Length - 6)</StatusBadge>
                            }
                        </div>
                        @if (_canManage)
                        {
                            <div class="form-actions">
                                <button class="action-button secondary" type="button" @onclick="() => EditRole(role)">Edytuj</button>
                                <button class="action-button danger" type="button" @onclick="() => DeleteRoleAsync(role.Id)">Usun</button>
                            </div>
                        }
                    </article>
                }
            </div>
        </article>

        <article class="panel-card">
            <SectionHeader Eyebrow="Edytor roli" Title="@(_roleForm.RoleId is null ? "Nowa rola biznesowa" : $"Edycja: {_roleForm.Name}")" />
            @if (_canManage)
            {
                <AccessRoleForm Model="_roleForm" Permissions="permissions" OnSave="SaveRoleAsync" OnReset="ResetRoleForm" />
            }
            else
            {
                <p class="empty-state">Masz tylko podglad. Zarzadzanie rolami wymaga uprawnienia <span class="mono">@PathoNetPermissions.UsersManage</span>.</p>
            }
        </article>
    </section>

    <section class="content-grid two-up">
        <article class="panel-card">
            <SectionHeader Eyebrow="Katalog uprawnien" Title="Dostepy do modulow i akcji" />
            <div class="stack-list">
                @foreach (var permission in permissions)
                {
                    <article class="stack-item">
                        <div class="pill-row">
                            <StatusBadge Tone="info">@permission.Category</StatusBadge>
                            <StatusBadge Kind="chip" Tone="info">@permission.Code</StatusBadge>
                        </div>
                        <strong>@permission.Name</strong>
                        <p>@permission.Description</p>
                    </article>
                }
            </div>
        </article>

        <article class="panel-card">
            <SectionHeader Eyebrow="Audyt" Title="Historia zmian administracyjnych" />
            <div class="stack-list">
                @if (auditLog.Length == 0)
                {
                    <p class="empty-state">Brak wpisow audytowych.</p>
                }
                else
                {
                    @foreach (var entry in auditLog)
                    {
                        <article class="stack-item">
                            <div class="pill-row">
                                <StatusBadge Tone="info">@entry.Action</StatusBadge>
                                <StatusBadge Kind="chip" Tone="info">@entry.SubjectType</StatusBadge>
                            </div>
                            <strong>@entry.Actor</strong>
                            <p>@entry.Summary</p>
                            <p class="detail-copy">@entry.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss") / @entry.SubjectId</p>
                        </article>
                    }
                }
            </div>
        </article>
    </section>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private PortalIdentityStateRecord? _state;
    private bool _loading = true;
    private string? _error;
    private string? _statusMessage;
    private string _statusTone = "info";
    private bool _canManage;
    private AccessUserFormModel _userForm = AccessUserFormModel.CreateEmpty();
    private AccessRoleFormModel _roleForm = AccessRoleFormModel.CreateEmpty();

    protected override async Task OnInitializedAsync() =>
        await LoadAsync();

    private async Task RefreshAsync() =>
        await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            var principal = (await AuthenticationStateTask).User;
            _canManage = principal.HasPermission(PathoNetPermissions.UsersManage);
            _state = await AccessService.GetStateAsync(CancellationToken.None);
        }
        catch (Exception ex)
        {
            _error = $"Nie udalo sie zaladowac bazy dostepu: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void EditUser(PortalIdentityUserRecord user) =>
        _userForm = AccessUserFormModel.FromUser(user);

    private void ResetUserForm() =>
        _userForm = AccessUserFormModel.CreateEmpty();

    private async Task SaveUserAsync()
    {
        if (!EnsureCanManage())
        {
            return;
        }

        var result = await AccessService.SaveUserAsync(
            new BlazorAccessUserInputRecord(
                UserId: _userForm.UserId,
                UserName: _userForm.UserName,
                FullName: _userForm.FullName,
                Email: _userForm.Email,
                Phone: _userForm.Phone,
                IsActive: _userForm.IsActive,
                IsServiceAccount: _userForm.IsServiceAccount,
                Password: _userForm.Password,
                RoleIds: _userForm.RoleIds.ToArray(),
                DirectPermissionIds: _userForm.DirectPermissionIds.ToArray()),
            CancellationToken.None);

        _statusMessage = result.Message;
        _statusTone = result.Success ? "online" : "critical";

        if (result.Success)
        {
            ResetUserForm();
            await LoadAsync();
        }
    }

    private async Task DeleteUserAsync(string userId)
    {
        if (!EnsureCanManage())
        {
            return;
        }

        var result = await AccessService.DeleteUserAsync(userId, CancellationToken.None);
        _statusMessage = result.Message;
        _statusTone = result.Success ? "online" : "critical";

        if (result.Success)
        {
            ResetUserForm();
            await LoadAsync();
        }
    }

    private void EditRole(PortalIdentityRoleRecord role) =>
        _roleForm = AccessRoleFormModel.FromRole(role);

    private void ResetRoleForm() =>
        _roleForm = AccessRoleFormModel.CreateEmpty();

    private async Task SaveRoleAsync()
    {
        if (!EnsureCanManage())
        {
            return;
        }

        var result = await AccessService.SaveRoleAsync(
            new BlazorAccessRoleInputRecord(
                RoleId: _roleForm.RoleId,
                Name: _roleForm.Name,
                Description: _roleForm.Description,
                PermissionIds: _roleForm.PermissionIds.ToArray()),
            CancellationToken.None);

        _statusMessage = result.Message;
        _statusTone = result.Success ? "online" : "critical";

        if (result.Success)
        {
            ResetRoleForm();
            await LoadAsync();
        }
    }

    private async Task DeleteRoleAsync(string roleId)
    {
        if (!EnsureCanManage())
        {
            return;
        }

        var result = await AccessService.DeleteRoleAsync(roleId, CancellationToken.None);
        _statusMessage = result.Message;
        _statusTone = result.Success ? "online" : "critical";

        if (result.Success)
        {
            ResetRoleForm();
            await LoadAsync();
        }
    }

    private bool EnsureCanManage()
    {
        if (_canManage)
        {
            return true;
        }

        _statusMessage = $"Brak uprawnienia {PathoNetPermissions.UsersManage}.";
        _statusTone = "critical";
        return false;
    }
}

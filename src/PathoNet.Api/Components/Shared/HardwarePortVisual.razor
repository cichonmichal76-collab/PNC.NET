@using PathoNet.Api.Components.Pages

<button class="@CssClass"
        type="button"
        style="@Style"
        title="@Title"
        aria-label="@Title"
        @onclick="HandleSelectAsync">
    <span class="sr-only">@Title</span>
    <span class="hardware-port-visual-frame"></span>
    <span class="hardware-port-visual-led"></span>
    <span class="hardware-port-visual-motion"></span>
    @if (string.Equals(Port.PortId, SuggestedPortId, StringComparison.OrdinalIgnoreCase))
    {
        <span class="hardware-port-visual-tag">auto</span>
    }
    @if (string.Equals(Port.PortId, SelectedPortId, StringComparison.OrdinalIgnoreCase))
    {
        <span class="hardware-port-visual-tag selected">wybrany</span>
    }
</button>

@code {
    [Parameter, EditorRequired] public HardwarePortStatusRecord Port { get; set; } = default!;
    [Parameter, EditorRequired] public HardwarePortLayoutDefinition Layout { get; set; } = default!;
    [Parameter] public string? SelectedPortId { get; set; }
    [Parameter] public string? SuggestedPortId { get; set; }
    [Parameter] public EventCallback<string> OnSelect { get; set; }

    private string CssClass
    {
        get
        {
            var stateClass = HardwareIntegrationWizardSupport.GetVisualStateClass(Port);
            var classes = $"hardware-port-visual {stateClass}";

            if (string.Equals(Port.PortId, SelectedPortId, StringComparison.OrdinalIgnoreCase))
            {
                classes += " is-selected";
            }

            if (string.Equals(Port.PortId, SuggestedPortId, StringComparison.OrdinalIgnoreCase))
            {
                classes += " is-suggested";
            }

            return classes;
        }
    }

    private string Style =>
        $"left:{Layout.Left.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}%;" +
        $"top:{Layout.Top.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}%;" +
        $"width:{Layout.Width.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}%;" +
        $"height:{Layout.Height.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}%;";

    private string Title =>
        $"{Port.PortId} / {Port.Alias} - {HardwareIntegrationWizardSupport.GetVisualStateLabel(Port)}. {Port.Summary}";

    private Task HandleSelectAsync() => OnSelect.InvokeAsync(Port.PortId);
}
